# Line Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/attendance_db

# Store GPS location (ตำแหน่งร้าน)
STORE_LAT=13.7563
STORE_LNG=100.5018
STORE_RADIUS_M=100

# Admin Line User IDs (คั่นด้วย comma)
ADMIN_LINE_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000

# Dashboard password
DASHBOARD_PASSWORD=changeme123
